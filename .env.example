# API Keys for Knowledge Extractor

# 1. SiliconFlow API (Used for Vision extraction via Qwen3.6)
# Get your key at: https://siliconflow.cn/
SILICONFLOW_API_KEY="your_siliconflow_api_key_here"

# 2. Kimi API (Used for final Markdown synthesis)
# Get your key at: https://platform.moonshot.cn/
KIMI_API_KEY="your_kimi_api_key_here"

# 3. GLM API (Fallback for Kimi when unavailable)
# Get your key at: https://z.ai/
GLM_API_KEY="your_glm_api_key_here"
